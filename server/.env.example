PORT=5000
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=truevoice_db
DB_SSL_ENABLED=false
DB_SSL_CA_PATH=
DB_SSL_REJECT_UNAUTHORIZED=true
JWT_SECRET=generate_64_char_random_string_here
JWT_REFRESH_SECRET=generate_different_64_char_random_string_here
JWT_EMAIL_SECRET=generate_third_64_char_random_string_here
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
EMAIL_VERIFY_EXPIRY=24h
PASSWORD_RESET_EXPIRY=30m
CLIENT_URL=http://localhost:5173
NODE_ENV=development
MAIL_FROM=TrueVoice <your_verified_sender@example.com>
SMTP_URL=
SMTP_HOST=smtp.postmarkapp.com
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=your_postmark_server_token
SMTP_PASS=your_postmark_server_token
SMTP_TIMEOUT_MS=8000
SMTP_FAMILY=4
SMTP_SERVERNAME=smtp.postmarkapp.com
POSTMARK_MESSAGE_STREAM=outbound
MEDIA_BACKEND=
ANTHROPIC_API_KEY=your_anthropic_api_key_here
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
PHASH_THRESHOLD=20
MAX_IMAGE_UPLOAD_SIZE=10485760
MAX_VIDEO_UPLOAD_SIZE=52428800
MAX_FILE_SIZE=52428800
RATE_LIMIT_API_MAX=900
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_REGISTER_MAX=5
RATE_LIMIT_AUTH_EMAIL_MAX=5
RATE_LIMIT_AUTH_TOKEN_MAX=60
RATE_LIMIT_WRITE_MAX=60
RATE_LIMIT_UPLOAD_MAX=20
RATE_LIMIT_SEARCH_MAX=30
RATE_LIMIT_MESSAGE_MAX=90
SOCKET_LIMIT_MESSAGE_SEND=60
SOCKET_LIMIT_TYPING=120
SOCKET_LIMIT_READ=120
SOCKET_LIMIT_RETRY=10
SOCKET_LIMIT_QUEUED=120
SOCKET_LIMIT_KEYS=30
SOCKET_LIMIT_CONVERSATION=20
